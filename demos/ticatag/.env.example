# Fallback for local dev WITHOUT Infisical.
# Copy to .env and fill in. Prefer ../../scripts/run-with-secrets.sh in normal use.

# Gradium voice/STT/TTS API key (Infisical: GRADIUM_TICATAG_API_KEY)
GRADIUM_API_KEY=

# LLM key (Infisical: LLM_API_KEY) — can equal GRADIUM_API_KEY if using the Gradium LLM proxy
LLM_API_KEY=

# Jira (gradium.atlassian.net, project KAN)
JIRA_EMAIL=colin@gradium.sh
JIRA_API_TOKEN=

# Local config for the Ticatag demo. Inherits from demos/config.yaml if present.
# Most secrets come from env vars (set via Infisical):
#   GRADIUM_API_KEY      -> mapped from GRADIUM_TICATAG_API_KEY in scripts/run-with-secrets.sh
#   LLM_API_KEY
#   JIRA_EMAIL           -> colin@gradium.ai
#   JIRA_API_TOKEN       -> Infisical secret `jira`

session:
  silence_timeout_s: 0.0
  assistant_speaks_first: true

tts:
  rewrite_rules: "fr"

stt:
  flush_duration_s: 0.5
